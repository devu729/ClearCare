# ── ClearCare Backend — copy this file to .env and fill in your values ──
# NEVER commit .env to Git — it is in .gitignore already

# Google Gemini (free, no credit card — get at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (Project Settings → API)
# Your URL is: https://kvxfldvpuguvndtcrxzh.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ChromaDB — local folder, no account needed
CHROMA_PERSIST_PATH=./chroma_db

# CORS — your frontend URL(s), comma separated
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.netlify.app

ENVIRONMENT=development
